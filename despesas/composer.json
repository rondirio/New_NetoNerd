{
    "name": "sistema/gerenciador-despesas",
    "description": "Sistema profissional de gerenciamento de despesas pessoais e empresariais",
    "type": "project",
    "keywords": [
        "despesas",
        "finanças",
        "controle-financeiro",
        "php",
        "mysql"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Rondineli",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=7.4",
        "phpmailer/phpmailer": "^6.8"
    },
    "autoload": {
        "psr-4": {
            "App\\": "classes/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
