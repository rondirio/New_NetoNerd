# ============================================================
# CONFIGURAÇÕES DO AMBIENTE - NetoNerd ITSM
# ============================================================
# IMPORTANTE: Copie este arquivo para .env e preencha com suas credenciais reais
# NUNCA FAÇA COMMIT do arquivo .env para o repositório!

# ============================================================
# BANCO DE DADOS
# ============================================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=netonerd_chamados
DB_USERNAME=root
DB_PASSWORD=

# ============================================================
# CONFIGURAÇÕES DE EMAIL (PHPMailer)
# ============================================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=seu-email@gmail.com
MAIL_PASSWORD=sua-senha-de-app
MAIL_FROM_EMAIL=netonerd@netonerd.com.br
MAIL_FROM_NAME=NetoNerd Suporte
MAIL_ENCRYPTION=tls

# ============================================================
# CONFIGURAÇÕES DO SISTEMA
# ============================================================
APP_NAME=NetoNerd ITSM
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/New_NetoNerd

# Chave secreta para criptografia (gere uma chave aleatória forte)
APP_SECRET_KEY=GERE_UMA_CHAVE_ALEATORIA_AQUI

# ============================================================
# CONFIGURAÇÕES DE SESSÃO
# ============================================================
SESSION_LIFETIME=3600
SESSION_SECURE=false
SESSION_HTTPONLY=true

# ============================================================
# CONFIGURAÇÕES DE UPLOAD
# ============================================================
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf,doc,docx,txt,zip,rar
UPLOAD_PATH=uploads/

# ============================================================
# REDIS (Para sistema JWT avançado - Opcional)
# ============================================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# ============================================================
# CONFIGURAÇÕES DE SEGURANÇA
# ============================================================
# Limite de tentativas de login antes do bloqueio
LOGIN_MAX_ATTEMPTS=5
LOGIN_BLOCK_TIME=300

# Habilitar proteção CSRF
CSRF_PROTECTION=true

# ============================================================
# NOTIFICAÇÕES
# ============================================================
# Ativar notificações por email
NOTIFICATIONS_EMAIL_ENABLED=true

# Ativar notificações internas
NOTIFICATIONS_INTERNAL_ENABLED=true

# ============================================================
# LOGS
# ============================================================
LOG_LEVEL=info
LOG_PATH=logs/
LOG_MAX_FILES=30
