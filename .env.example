# ============================================================
# CONFIGURAÇÕES DO AMBIENTE - NetoNerd ITSM
# ============================================================
# IMPORTANTE: Copie este arquivo para .env e preencha com suas credenciais reais
# NUNCA FAÇA COMMIT do arquivo .env para o repositório!

# ============================================================
# BANCO DE DADOS
# ============================================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=netonerd_chamados
DB_USERNAME=root
DB_PASSWORD=

# ============================================================
# BANCO DE DADOS - MÓDULOS ADICIONAIS
# ============================================================
# Cada módulo tem seu próprio banco de dados — preencha só o que for usar.

# Super Admin (login/gestão de equipe NetoNerd) — app/Views/superadmin/
SUPERADMIN_DB_HOST=localhost
SUPERADMIN_DB_NAME=netonerd_adm_super
SUPERADMIN_DB_USERNAME=
SUPERADMIN_DB_PASSWORD=

# Super Admin API (geração/validação de JWT de tenants) — admin/super_admin/
SUPERADMIN_API_DB_HOST=localhost
SUPERADMIN_API_DB_NAME=super_admin_netonerd
SUPERADMIN_API_DB_USERNAME=
SUPERADMIN_API_DB_PASSWORD=

# API key mestra exigida no header X-Api-Key para acessar admin/super_admin/api/ (geração/revogação de JWT de tenant)
SUPERADMIN_API_MASTER_KEY=GERE_UMA_CHAVE_ALEATORIA_FORTE_AQUI

# Módulo financeiro (despesas/)
DESPESAS_DB_HOST=localhost
DESPESAS_DB_NAME=
DESPESAS_DB_USER=
DESPESAS_DB_PASS=

# Conexão legada em app/Database/ (avaliar remoção — ver docs/AUDITORIA_BACKEND.md, BE11)
APP_LEGACY_DB_HOST=localhost
APP_LEGACY_DB_NAME=netonerd_chamados
APP_LEGACY_DB_USERNAME=
APP_LEGACY_DB_PASSWORD=

# ============================================================
# STYLEMANAGER API (api/v1/stylemanager/)
# ============================================================
STYLEMANAGER_AMBIENTE=development
STYLEMANAGER_JWT_SECRET=GERE_UMA_CHAVE_ALEATORIA_FORTE_AQUI

# ============================================================
# CONFIGURAÇÕES DE EMAIL (PHPMailer)
# ============================================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=seu-email@gmail.com
MAIL_PASSWORD=sua-senha-de-app
MAIL_FROM_EMAIL=netonerd@netonerd.com.br.br
MAIL_FROM_NAME=NetoNerd Suporte
MAIL_ENCRYPTION=tls

# ============================================================
# CONFIGURAÇÕES DO SISTEMA
# ============================================================
APP_NAME=NetoNerd ITSM
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/NetoNerd/New_NetoNerd-main

# Chave secreta para criptografia (gere uma chave aleatória forte)
APP_SECRET_KEY=GERE_UMA_CHAVE_ALEATORIA_AQUI

# ============================================================
# CONFIGURAÇÕES DE SESSÃO
# ============================================================
SESSION_LIFETIME=3600
SESSION_SECURE=false
SESSION_HTTPONLY=true

# ============================================================
# CONFIGURAÇÕES DE UPLOAD
# ============================================================
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf,doc,docx,txt,zip,rar
UPLOAD_PATH=uploads/

# ============================================================
# REDIS (Para sistema JWT avançado - Opcional)
# ============================================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# ============================================================
# CONFIGURAÇÕES DE SEGURANÇA
# ============================================================
# Limite de tentativas de login antes do bloqueio
LOGIN_MAX_ATTEMPTS=5
LOGIN_BLOCK_TIME=300

# Habilitar proteção CSRF
CSRF_PROTECTION=true

# ============================================================
# NOTIFICAÇÕES
# ============================================================
# Ativar notificações por email
NOTIFICATIONS_EMAIL_ENABLED=true

# Ativar notificações internas
NOTIFICATIONS_INTERNAL_ENABLED=true

# ============================================================
# LOGS
# ============================================================
LOG_LEVEL=info
LOG_PATH=logs/
LOG_MAX_FILES=30
